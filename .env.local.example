# Public URL clients use to reach the API.
# In dev, defaults to http://localhost:8080 if not set.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Server-only override (used by RSC fetchers). Falls back to NEXT_PUBLIC_API_BASE_URL.
# Useful in Docker where the BE is reachable by service name only from the server.
# API_BASE_URL=http://landing-be:8080
